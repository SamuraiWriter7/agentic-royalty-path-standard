{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/agentic-royalty-path.schema.json",
  "title": "Agentic Royalty Path",
  "description": "A minimal standard for recording AI agent action paths, browser action receipts, execution logs, audit status, and royalty candidate mapping.",
  "type": "object",
  "additionalProperties": false,
  "required": ["agentic_royalty_path"],
  "properties": {
    "agentic_royalty_path": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "path_id",
        "goal",
        "path_layer",
        "action_receipts",
        "audit",
        "royalty_mapping"
      ],
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "path_id": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "goal": {
          "type": "object",
          "additionalProperties": false,
          "required": ["intent", "origin_ref", "expected_outcome"],
          "properties": {
            "intent": {
              "type": "string"
            },
            "origin_ref": {
              "type": "string"
            },
            "expected_outcome": {
              "type": "string"
            }
          }
        },
        "path_layer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["route_type", "steps"],
          "properties": {
            "route_type": {
              "type": "string"
            },
            "wayfinder_ref": {
              "type": "string"
            },
            "steps": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["step_id", "action_type", "target", "purpose"],
                "properties": {
                  "step_id": {
                    "type": "string"
                  },
                  "action_type": {
                    "type": "string",
                    "enum": [
                      "open_page",
                      "navigate",
                      "click",
                      "type_input",
                      "observe",
                      "screenshot",
                      "read_page",
                      "run_script",
                      "test_run",
                      "other"
                    ]
                  },
                  "target": {
                    "type": "string"
                  },
                  "purpose": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "action_receipts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["receipt_id", "step_ref", "action_type", "evidence_hash"],
            "properties": {
              "receipt_id": {
                "type": "string"
              },
              "step_ref": {
                "type": "string"
              },
              "action_type": {
                "type": "string"
              },
              "evidence_hash": {
                "type": "string"
              }
            }
          }
        },
        "agent_log": {
          "type": "object",
          "additionalProperties": false,
          "required": ["session_id", "environment", "tool_calls", "errors", "duration_ms"],
          "properties": {
            "session_id": {
              "type": "string"
            },
            "environment": {
              "type": "string"
            },
            "tool_calls": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "errors": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "duration_ms": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "path_hash_chain": {
          "type": "object",
          "additionalProperties": false,
          "required": ["step_hashes", "chain_hash"],
          "properties": {
            "step_hashes": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["step_id", "hash"],
                "properties": {
                  "step_id": {
                    "type": "string"
                  },
                  "hash": {
                    "type": "string"
                  }
                }
              }
            },
            "chain_hash": {
              "type": "string"
            }
          }
        },
        "monetization_event": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "event_ref": {
              "type": ["string", "null"]
            },
            "provider": {
              "type": ["string", "null"]
            },
            "protocol": {
              "type": ["string", "null"]
            }
          }
        },
        "audit": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "permission_boundary",
            "reproducible",
            "human_review_required",
            "audit_status"
          ],
          "properties": {
            "permission_boundary": {
              "type": "string"
            },
            "reproducible": {
              "type": "boolean"
            },
            "human_review_required": {
              "type": "boolean"
            },
            "audit_status": {
              "type": "string",
              "enum": [
                "pending_review",
                "confirmed",
                "rejected",
                "needs_more_evidence"
              ]
            }
          }
        },
        "royalty_mapping": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "origin_events",
            "derivative_events",
            "legal_claim_created"
          ],
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "candidate",
                "confirmed",
                "rejected",
                "not_applicable"
              ]
            },
            "origin_events": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "derivative_events": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "legal_claim_created": {
              "type": "boolean"
            }
          }
        }
      }
    }
  }
}
