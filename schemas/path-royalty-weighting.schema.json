{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/path-royalty-weighting.schema.json",
  "title": "Path Royalty Weighting",
  "description": "A candidate weighting record for mapping AI agent value-generation paths, action receipts, monetization events, and contributor roles into royalty candidate shares.",
  "type": "object",
  "additionalProperties": false,
  "required": ["path_royalty_weighting"],
  "properties": {
    "path_royalty_weighting": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "weighting_id",
        "path_ref",
        "scoring_model",
        "scoring_factors",
        "royalty_candidates",
        "audit"
      ],
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "weighting_id": {
          "type": "string",
          "minLength": 1
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "path_ref": {
          "type": "string",
          "minLength": 1
        },
        "monetization_event_ref": {
          "type": ["string", "null"]
        },
        "scoring_model": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "model_type",
            "normalization",
            "total_weight"
          ],
          "properties": {
            "model_type": {
              "type": "string",
              "enum": [
                "manual_candidate",
                "rule_based_candidate",
                "payment_aware_candidate",
                "hybrid_candidate",
                "other"
              ]
            },
            "normalization": {
              "type": "string",
              "enum": [
                "sum_to_one",
                "percentage",
                "points",
                "other"
              ]
            },
            "total_weight": {
              "type": "number",
              "minimum": 0
            },
            "notes": {
              "type": "string"
            }
          }
        },
        "scoring_factors": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "path_complexity",
            "origin_dependency",
            "action_receipt_confidence",
            "monetization_signal",
            "agent_decision_depth",
            "human_review_depth",
            "reproducibility_score"
          ],
          "properties": {
            "path_complexity": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "origin_dependency": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "action_receipt_confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "monetization_signal": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "agent_decision_depth": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "human_review_depth": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "reproducibility_score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            }
          }
        },
        "royalty_candidates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "candidate_id",
              "role",
              "beneficiary_ref",
              "contribution_basis",
              "suggested_share",
              "evidence_refs"
            ],
            "properties": {
              "candidate_id": {
                "type": "string"
              },
              "role": {
                "type": "string",
                "enum": [
                  "origin_author",
                  "test_flow_author",
                  "ui_component_author",
                  "path_designer",
                  "browser_action_script_author",
                  "resource_owner",
                  "agent_operator",
                  "human_reviewer",
                  "marketplace_rule_engine",
                  "other"
                ]
              },
              "beneficiary_ref": {
                "type": "string"
              },
              "contribution_basis": {
                "type": "string"
              },
              "suggested_share": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "evidence_refs": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              },
              "notes": {
                "type": "string"
              }
            }
          }
        },
        "payment_context": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "payment_aware",
            "payment_event_refs"
          ],
          "properties": {
            "payment_aware": {
              "type": "boolean"
            },
            "payment_event_refs": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "gross_amount_ref": {
              "type": ["string", "null"]
            },
            "currency_ref": {
              "type": ["string", "null"]
            }
          }
        },
        "audit": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "weighting_status",
            "legal_claim_created",
            "requires_human_review",
            "review_status"
          ],
          "properties": {
            "weighting_status": {
              "type": "string",
              "enum": [
                "candidate",
                "confirmed",
                "rejected",
                "needs_more_evidence"
              ]
            },
            "legal_claim_created": {
              "type": "boolean"
            },
            "requires_human_review": {
              "type": "boolean"
            },
            "review_status": {
              "type": "string",
              "enum": [
                "not_reviewed",
                "under_review",
                "reviewed",
                "disputed"
              ]
            },
            "notes": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
